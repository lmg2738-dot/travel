# TripMind AI - 환경 변수
# .env.local 파일에 실제 값을 입력하세요. (.gitignore로 Git 제외됨)

# OpenRouter (무료 모델 사용 - https://openrouter.ai/models?max_price=0)
OPENROUTER_API_KEY=

# Google Maps Platform (Maps JavaScript API)
# https://console.cloud.google.com/google/maps-apis
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# AI HUB (aihubshell API key - https://aihub.or.kr 에서 발급)
AIHUB_API_KEY=
# AIHUB_API_BASE_URL=https://api.aihub.or.kr
