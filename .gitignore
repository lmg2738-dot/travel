# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# AI HUB shell binary (로컬 참조용, 커밋 제외)
/bin/

# 로컬 여행 데이터 (JSON 파일 저장)
/data/trips/

# typescript
*.tsbuildinfo
next-env.d.ts
